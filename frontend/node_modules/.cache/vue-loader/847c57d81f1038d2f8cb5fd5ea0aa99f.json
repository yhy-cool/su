{"remainingRequest":"C:\\Users\\y'h\\Desktop\\苏士杰\\蓝月亮定稿版\\frontend\\node_modules\\vue-loader\\lib\\index.js??vue-loader-options!C:\\Users\\y'h\\Desktop\\苏士杰\\蓝月亮定稿版\\frontend\\src\\components\\layout\\AdminLayout.vue?vue&type=style&index=0&id=5dcbcfe4&scoped=true&lang=css","dependencies":[{"path":"C:\\Users\\y'h\\Desktop\\苏士杰\\蓝月亮定稿版\\frontend\\src\\components\\layout\\AdminLayout.vue","mtime":1773665100796},{"path":"C:\\Users\\y'h\\Desktop\\苏士杰\\蓝月亮定稿版\\frontend\\node_modules\\css-loader\\dist\\cjs.js","mtime":1778748357146},{"path":"C:\\Users\\y'h\\Desktop\\苏士杰\\蓝月亮定稿版\\frontend\\node_modules\\vue-loader\\lib\\loaders\\stylePostLoader.js","mtime":1778748359154},{"path":"C:\\Users\\y'h\\Desktop\\苏士杰\\蓝月亮定稿版\\frontend\\node_modules\\postcss-loader\\src\\index.js","mtime":1778748354851},{"path":"C:\\Users\\y'h\\Desktop\\苏士杰\\蓝月亮定稿版\\frontend\\node_modules\\cache-loader\\dist\\cjs.js","mtime":1778748357469},{"path":"C:\\Users\\y'h\\Desktop\\苏士杰\\蓝月亮定稿版\\frontend\\node_modules\\vue-loader\\lib\\index.js","mtime":1778748355199}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["AdminLayout.vue"],"names":[],"mappings":";AAyFA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA","file":"AdminLayout.vue","sourceRoot":"src/components/layout","sourcesContent":["<template>\n  <div class=\"admin-layout\">\n    <!-- 侧边导航栏 -->\n    <aside class=\"aside\">\n      <div class=\"aside-header\">\n        <h2>管理员后台</h2>\n      </div>\n      <nav class=\"nav-menu\">\n        <!-- 商品管理菜单 -->\n        <div class=\"nav-item\">\n          <a @click=\"navigateTo('/admin/products')\" class=\"nav-item-header\">\n            <span class=\"nav-icon\">📦</span>\n            <span class=\"nav-title\">商品管理</span>\n          </a>\n        </div>\n        \n        <!-- 用户管理菜单 -->\n        <div class=\"nav-item\">\n          <a @click=\"navigateTo('/admin/users')\" class=\"nav-item-header\">\n            <span class=\"nav-icon\">👥</span>\n            <span class=\"nav-title\">用户管理</span>\n          </a>\n        </div>\n        \n        <!-- 订单管理菜单 -->\n        <div class=\"nav-item\">\n          <a @click=\"navigateTo('/admin/orders')\" class=\"nav-item-header\">\n            <span class=\"nav-icon\">📋</span>\n            <span class=\"nav-title\">订单管理</span>\n          </a>\n        </div>\n      </nav>\n    </aside>\n    \n    <!-- 主内容区域 -->\n    <main class=\"main\">\n      <div class=\"main-header\">\n        <h1>{{ currentTitle }}</h1>\n      </div>\n      <div class=\"main-content\">\n        <router-view></router-view>\n      </div>\n    </main>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'AdminLayout',\n  data() {\n    return {\n      currentTitle: '商品管理'\n    };\n  },\n  methods: {\n    navigateTo(path) {\n      // 检查当前路由是否与目标路由相同，避免重复导航错误\n      if (this.$route.path !== path) {\n        this.$router.push(path);\n      }\n      // 更新当前标题\n      this.updateTitle(path);\n    },\n    updateTitle(path) {\n      if (path.includes('/admin/products')) {\n        this.currentTitle = '商品管理';\n      } else if (path.includes('/admin/users')) {\n        this.currentTitle = '用户管理';\n      } else if (path.includes('/admin/orders')) {\n        this.currentTitle = '订单管理';\n      } else {\n        this.currentTitle = '管理员后台';\n      }\n    }\n  },\n  mounted() {\n    // 初始化当前标题\n    this.updateTitle(this.$route.path);\n  },\n  watch: {\n    // 监听路由变化，更新标题\n    '$route.path': function(newPath) {\n      this.updateTitle(newPath);\n    }\n  }\n};\n</script>\n\n<style scoped>\n.admin-layout {\n  display: flex;\n  width: 100vw;\n  height: 100vh;\n  overflow: hidden;\n}\n\n/* 侧边导航栏 */\n.aside {\n  width: 200px;\n  background-color: #343a40;\n  color: white;\n  display: flex;\n  flex-direction: column;\n  overflow-y: auto;\n}\n\n.aside-header {\n  padding: 20px;\n  border-bottom: 1px solid #495057;\n  text-align: center;\n}\n\n.aside-header h2 {\n  margin: 0;\n  color: #4CAF50;\n  font-size: 18px;\n}\n\n.nav-menu {\n  flex: 1;\n  padding: 10px 0;\n}\n\n.nav-item {\n  margin-bottom: 5px;\n}\n\n.nav-item-header {\n  display: flex;\n  align-items: center;\n  padding: 15px 20px;\n  cursor: pointer;\n  transition: background-color 0.3s;\n  border-left: 3px solid transparent;\n  text-decoration: none;\n  color: white;\n}\n\n.nav-item-header:hover {\n  background-color: #495057;\n  border-left-color: #4CAF50;\n}\n\n.nav-icon {\n  font-size: 18px;\n  margin-right: 10px;\n}\n\n.nav-title {\n  flex: 1;\n  font-size: 15px;\n  font-weight: 500;\n}\n\n/* 主内容区域 */\n.main {\n  flex: 1;\n  display: flex;\n  flex-direction: column;\n  overflow: hidden;\n}\n\n.main-header {\n  padding: 20px 30px;\n  border-bottom: 1px solid #e9ecef;\n  background-color: #ffffff;\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n}\n\n.main-header h1 {\n  margin: 0;\n  font-size: 20px;\n  color: #333;\n}\n\n.main-content {\n  flex: 1;\n  padding: 30px;\n  overflow-y: auto;\n  background-color: #f8f9fa;\n}\n</style>"]}]}